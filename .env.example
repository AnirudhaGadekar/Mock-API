# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database (PgBouncer-ready with transaction pooling)
DATABASE_URL="postgresql://MockAPI:MockAPI_pass@localhost:5432/MockAPI?schema=public&pgbouncer=true&connection_limit=1"
DIRECT_DATABASE_URL="postgresql://MockAPI:MockAPI_pass@localhost:5432/MockAPI?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth Mode
# Values: 'otp' (production) | 'dev-bypass' (local dev, skips email)
AUTH_MODE=dev-bypass
# Optional: allow OTP login for users that have a password (default: false)
ALLOW_OTP_FOR_PASSWORD_USERS=false

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Preferred token expiry variable (supports values like 7d / 1h)
JWT_EXPIRES_IN=7d
# Backward-compatible alias read by OTP auth
JWT_EXPIRY=7d

# Optional: expose stack traces in API error responses (default: false)
EXPOSE_STACK_TRACE=false
# Optional cookie max age in seconds (or duration like 7d)
API_KEY_COOKIE_MAX_AGE_SECONDS=7d
API_KEY_COOKIE_DOMAIN=

# API Key Hashing (Required in production)
API_KEY_SECRET="your-secure-random-string-at-least-32-chars"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
REQUEST_LOG_RETENTION_DAYS=10
ENDPOINT_INACTIVITY_DAYS=0

# CORS
CORS_ORIGIN=https://mockapi.online,http://localhost:5173

# API
API_VERSION=v1
# Production example: https://api.mockapi.online/e
BASE_ENDPOINT_URL=https://api.mockapi.online/e
# Production example: mockapi.online
BASE_MOCK_DOMAIN=mockapi.online

# Email OTP (Resend)
RESEND_API_KEY=re_your_api_key
RESEND_FROM=onboarding@mockapi.online
OTP_SECRET=your-otp-hmac-secret

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.mockapi.online/api/v2/oauth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.mockapi.online/api/v2/oauth/github/callback

# Frontend URL (used by OAuth callbacks)
# Production example: https://mockapi.online
FRONTEND_URL=https://mockapi.online

# Admin Dashboard
ADMIN_SECRET=your-admin-secret-key
