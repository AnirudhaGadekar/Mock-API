# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database (PgBouncer-ready with transaction pooling)
DATABASE_URL="postgresql://MockUrl:MockUrl_pass@localhost:5432/MockUrl?schema=public&pgbouncer=true&connection_limit=1"
DIRECT_DATABASE_URL="postgresql://MockUrl:MockUrl_pass@localhost:5432/MockUrl?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# API
API_VERSION=v1
BASE_ENDPOINT_URL=http://localhost:3000/e
