generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================
// USER MODEL
// ============================================
model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  password              String?        // NULL for OAuth and anonymous users
  username              String?        @unique
  firstName             String?
  lastName              String?
  name                  String?
  picture               String?        // Profile picture URL
  
  // Email verification
  emailVerified         Boolean        @default(false)
  verificationToken     String?        @unique
  
  // Auth provider tracking
  authProvider          AuthProvider   @default(ANONYMOUS)
  googleId              String?        @unique
  githubId              String?        @unique
  
  // API Key for authentication (Stored as SHA-256 hash)
  apiKeyHash            String         @unique
  
  // Current workspace context
  currentWorkspaceType  WorkspaceType  @default(PERSONAL)
  currentTeamId         String?
  
  // Timestamps
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  
  // Relations
  endpoints             Endpoint[]
  ownedTeams            Team[]         @relation("TeamOwner")
  teamMemberships       TeamMember[]
  createdInvites        TeamInvite[]   @relation("InviteCreator")
  requestLogs           RequestLog[]
  endpointAuditLogs     EndpointAuditLog[]
  
  @@index([email])
  @@index([username])
  @@index([apiKeyHash])
  @@index([googleId])
  @@index([githubId])
}

enum AuthProvider {
  ANONYMOUS
  LOCAL
  GOOGLE
  GITHUB
  EMAIL_OTP
}

enum WorkspaceType {
  PERSONAL
  TEAM
}

enum EndpointAuditAction {
  CREATED
  UPDATED
  DELETED
}

// ============================================
// TEAM MODELS
// ============================================
model Team {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  
  // Owner
  ownerId     String
  owner       User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Relations
  members     TeamMember[]
  endpoints   Endpoint[]
  invites     TeamInvite[]
  
  @@index([slug])
  @@index([ownerId])
}

model TeamMember {
  id        String     @id @default(uuid())
  role      TeamRole   @default(MEMBER)
  joinedAt  DateTime   @default(now())
  
  // Relations
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  @@unique([userId, teamId], name: "userId_teamId")
  @@index([userId])
  @@index([teamId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model TeamInvite {
  id            String    @id @default(uuid())
  token         String    @unique
  
  // Invite settings
  email         String
  role          TeamRole  @default(MEMBER)
  expiresAt     DateTime
  maxUses       Int?      // NULL = unlimited
  usedCount     Int       @default(0)
  acceptedAt    DateTime?
  
  // Relations
  teamId        String
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  createdById   String
  createdBy     User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
  
  @@index([token])
  @@index([teamId])
}

// ============================================
// ENDPOINT MODEL
// ============================================
model Endpoint {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  
  // Response configuration
  rules        Json      // Array of rules [{ path, method, response: { status, body, headers, delay }, condition: {...} }]
  settings     Json?     // Global endpoint settings
  
  requestCount Int       @default(0)
  lastActiveAt DateTime? @default(now())
  
  // Ownership - belongs to EITHER user OR team
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  teamId       String?
  team         Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Logs
  requestLogs  RequestLog[]
  auditLogs    EndpointAuditLog[]
  
  @@index([slug])
  @@index([userId])
  @@index([teamId])
}

model EndpointAuditLog {
  id          String              @id @default(uuid())
  action      EndpointAuditAction

  endpointId  String?
  endpoint    Endpoint?           @relation(fields: [endpointId], references: [id], onDelete: SetNull)
  endpointSlug String?
  endpointName String?

  actorUserId String?
  actorUser   User?               @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  workspaceType WorkspaceType
  teamId      String?
  ip          String?
  userAgent   String?
  details     Json?
  createdAt   DateTime            @default(now())

  @@index([endpointId])
  @@index([endpointId, createdAt])
  @@index([endpointSlug])
  @@index([actorUserId])
  @@index([createdAt])
  @@index([workspaceType])
  @@index([teamId])
}

// ============================================
// OTP MODEL
// ============================================
model Otp {
  id        String   @id @default(cuid())
  email     String
  hash      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ============================================
// REQUEST LOG MODEL
// ============================================
model RequestLog {
  id          String   @id @default(uuid())
  endpointId  String
  endpoint    Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  
  method      String
  path        String
  queryParams Json?
  headers     Json?
  body        Json?
  
  ip          String?
  userAgent   String?
  
  responseStatus Int
  durationMs     Int
  
  createdAt   DateTime @default(now())

  // Optional: Link log to a user if authenticated (e.g. for audits)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([endpointId])
  @@index([endpointId, createdAt])
  @@index([createdAt])
  @@index([userId])
}
