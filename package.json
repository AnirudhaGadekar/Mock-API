{
  "name": "mockurl",
  "version": "1.0.0",
  "description": "Scalable TypeScript/Fastify backend for MockUrl - MockUrl-style mock API",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "npm run prisma:deploy && node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:integration": "vitest run --reporter=verbose tests/integration.production-mode.test.ts tests/integration.rollback.test.ts tests/integration.crash.test.ts",
    "test:integration:live": "vitest run --reporter=verbose tests/integration.infrastructure.test.ts tests/integration.auth-flow.test.ts tests/integration.cors.test.ts",
    "test:stability": "vitest run tests/integration.rollback.test.ts tests/integration.crash.test.ts",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx src/prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v",
    "typecheck": "tsc --noEmit",
    "scan:project": "ts-node scripts/project-scan.ts",
    "scan:security": "ts-node scripts/security-scan.ts",
    "scan:production": "ts-node scripts/production-check.ts",
    "scan:all": "npm run scan:project && npm run scan:security && npm run scan:production",
    "load:test": "ts-node scripts/load-otp-test.ts",
    "memory:test": "node --expose-gc scripts/memory-test.ts",
    "stability:test": "npm run load:test && npm run memory:test && npm run test:stability",
    "stability:test:local": "npm run memory:test && npm run test:stability",
    "verify:all": "ts-node scripts/production-verification.ts",
    "verify:production": "ts-node scripts/production-verification.ts",
    "verify:local": "npm run build && npm run scan:all && npm run test:integration && npm run stability:test:local"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@faker-js/faker": "^10.3.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/client": "^6.2.0",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^6.1.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.1",
    "path-to-regexp": "^8.3.0",
    "postgres": "^3.4.8",
    "resend": "^6.9.2",
    "winston": "^3.17.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/config": "^7.4.0",
    "@types/autocannon": "^7.12.7",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.10",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/coverage-v8": "^2.1.8",
    "autocannon": "^8.0.0",
    "cross-fetch": "^4.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "madge": "^8.0.0",
    "prisma": "^6.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "MockUrl",
    "mock",
    "api",
    "fastify",
    "typescript",
    "prisma",
    "redis"
  ],
  "author": "",
  "license": "MIT",
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
